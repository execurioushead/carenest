generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  role String @default("patient")

  accounts     Account[]
  sessions     Session[]
  appointments Appointment[]

  doctorProfile Doctor?
}

model Doctor {
  id Int @id @default(autoincrement())

  userId String? @unique

  name       String
  specialty  String
  experience Int
  fee        Int
  location   String
  available  Boolean @default(true)

  qualifications String?
  about          String?

  appointments Appointment[]

  user User? @relation(fields: [userId], references: [id])
  availableSlots Json?
  
}

model Appointment {
  id       Int     @id @default(autoincrement())
  userId   String?
  doctorId Int

  patientName  String
  patientPhone String
  time         String

  paymentId     String?
  paymentStatus String  @default("pending")
  amountPaid    Int?

  date      DateTime
  status    String   @default("confirmed")
  createdAt DateTime @default(now())

  user   User?  @relation(fields: [userId], references: [id])
  doctor Doctor @relation(fields: [doctorId], references: [id])
}

model LabTestOrder {
  id           Int      @id @default(autoincrement())
  patientName  String
  patientPhone String
  testName     String
  date         DateTime
  status       String   @default("scheduled")
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model DoctorSlot {
  id        Int      @id @default(autoincrement())
  doctorId  Int
  date      DateTime
  time      String
  available Boolean @default(true)

  doctor Doctor @relation(fields: [doctorId], references: [id])
}
